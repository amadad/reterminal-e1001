# reTerminal E1001 Configuration
# Copy this file to .env and customize as needed

# Device IP address (required)
RETERMINAL_HOST=192.168.7.77

# Request timeout in seconds
RETERMINAL_TIMEOUT=30

# Logging level (DEBUG, INFO, WARNING, ERROR)
RETERMINAL_LOG_LEVEL=INFO

# Retry configuration for network failures
RETERMINAL_RETRY_ATTEMPTS=3
RETERMINAL_RETRY_MIN_WAIT=1
RETERMINAL_RETRY_MAX_WAIT=10
