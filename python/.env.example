# reTerminal E1001 Configuration
# Copy this file to .env and customize as needed

# Device host (required for commands that target one device)
# Discover first, then set the current DHCP lease or mDNS name:
#   uv run reterminal discover
#   export RETERMINAL_HOST=<device-ip-or-reterminal.local>
RETERMINAL_HOST=

# Request timeout in seconds
RETERMINAL_TIMEOUT=30

# Logging level (DEBUG, INFO, WARNING, ERROR)
RETERMINAL_LOG_LEVEL=INFO

# Retry configuration for network failures
RETERMINAL_RETRY_ATTEMPTS=3
RETERMINAL_RETRY_MIN_WAIT=1
RETERMINAL_RETRY_MAX_WAIT=10
