<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Launchd agent example for the kitchen-display publisher.

  Install:
    1. Copy this file to ~/Library/LaunchAgents/sh.reterminal.publish.plist
    2. Replace /path/to/reterminal-e1001 with your local checkout path.
    3. Optionally set RETERMINAL_HOST or RETERMINAL_DISCOVERY_SUBNET.
    4. launchctl load ~/Library/LaunchAgents/sh.reterminal.publish.plist

  Tail logs:
    tail -F ~/Library/Logs/reterminal/publish.log

  Notes:
    - KeepAlive=true restarts the publisher if it crashes.
    - RunAtLoad=true starts it immediately on load and on user login.
    - The watch loop blocks on FSEvents; no --interval needed.
    - The wrapper discovers the DHCP-assigned device unless RETERMINAL_HOST is set.
    - Keep your installed plist local; do not commit machine-specific paths or IPs.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>sh.reterminal.publish</string>

    <key>WorkingDirectory</key>
    <string>/path/to/reterminal-e1001/python</string>

    <key>ProgramArguments</key>
    <array>
        <string>/path/to/reterminal-e1001/scripts/reterminal-publish-watch.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <!-- Optional examples:
        <key>RETERMINAL_HOST</key>
        <string>192.168.1.50</string>
        <key>RETERMINAL_DISCOVERY_SUBNET</key>
        <string>192.168.1</string>
        <key>RETERMINAL_FEED</key>
        <string>/path/to/reterminal-e1001/python/examples/kitchen-display.local.json</string>
        -->
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/tmp/reterminal-publish.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/reterminal-publish.log</string>
</dict>
</plist>
