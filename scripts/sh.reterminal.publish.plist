<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Launchd agent for the kitchen-display publisher.

  Install:
    cp scripts/sh.reterminal.publish.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/sh.reterminal.publish.plist

  Tail logs:
    tail -F ~/Library/Logs/reterminal/publish.log

  Reload after editing:
    launchctl unload ~/Library/LaunchAgents/sh.reterminal.publish.plist
    launchctl load ~/Library/LaunchAgents/sh.reterminal.publish.plist

  Notes:
    - KeepAlive=true restarts the publisher if it crashes.
    - RunAtLoad=true starts it immediately on load and on user login.
    - The watch loop blocks on FSEvents; no --interval needed.
    - The wrapper discovers the DHCP-assigned device unless RETERMINAL_HOST is set.
    - Adjust paths below for your install (uv path, repo path).
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>sh.reterminal.publish</string>

    <key>WorkingDirectory</key>
    <string>/Users/amadad/projects/reterminal-e1001/python</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/amadad/projects/reterminal-e1001/scripts/reterminal-publish-watch.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/amadad/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>RETERMINAL_DISCOVERY_SUBNET</key>
        <string>192.168.7</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/amadad/Library/Logs/reterminal/publish.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/amadad/Library/Logs/reterminal/publish.log</string>
</dict>
</plist>
